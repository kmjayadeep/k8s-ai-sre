export SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

export TELEGRAM_BOT_TOKEN=$(pass k8s-ai-sre/telegram-token)
export TELEGRAM_CHAT_ID=$(pass k8s-ai-sre/telegram-chat-id)
export TELEGRAM_ALLOWED_CHAT_IDS=$(pass k8s-ai-sre/telegram-chat-id)

export WRITE_ALLOWED_NAMESPACES=torrents

export MODEL_PROVIDER=minimax
export MODEL_NAME=MiniMax-M2.7
export MODEL_BASE_URL=https://api.minimax.io/v1
export MODEL_API_KEY=$(pass k8s-ai-sre/minimax-api-key)
